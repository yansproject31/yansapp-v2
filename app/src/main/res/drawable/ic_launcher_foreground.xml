<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle Golden Outer Halo Ring in Foreground -->
    <item
        android:width="62dp"
        android:height="62dp"
        android:gravity="center">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#33C6A15B" />
            <solid android:color="#05C6A15B" />
        </shape>
    </item>

    <!-- Inner Golden Frame Ring -->
    <item
        android:width="54dp"
        android:height="54dp"
        android:gravity="center">
        <shape android:shape="oval">
            <stroke
                android:width="0.8dp"
                android:color="#55C6A15B" />
        </shape>
    </item>

    <!-- The YANSPROJECT.ID Logo - Sized at 46dp x 46dp to ensure ZERO clipping on circular, squircle, or rounded masks -->
    <item
        android:width="46dp"
        android:height="46dp"
        android:drawable="@drawable/ic_logo"
        android:gravity="center" />
</layer-list>

